generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// One row per device/browser. Created automatically on first API call.
model User {
  id          String       @id
  createdAt   DateTime     @default(now())
  habits      Habit[]
  completions Completion[]
}

// Each user owns their own habits selected during onboarding (or added later).
model Habit {
  id          Int          @id @default(autoincrement())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  completions Completion[]

  @@index([userId])
  @@index([userId, isActive])
}

// userId is denormalised here so every query can filter by userId
// directly without a JOIN through Habit — enables the fast index below.
model Completion {
  id        Int      @id @default(autoincrement())
  habitId   Int
  userId    String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD

  @@unique([habitId, date])          // prevents duplicate completions
  @@index([userId, date])            // primary read path: user's completions on a date
  @@index([habitId])                 // cascade deletes
  @@index([date])                    // calendar range scans
}
